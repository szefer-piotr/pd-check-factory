{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pd-check-factory/schemas/deviations_parsed_v2.schema.json",
  "title": "Parsed deviations V2",
  "type": "object",
  "required": ["schema_version", "study_id", "generated_at", "deviations"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "study_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "deviations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["deviation_id", "rule_id", "text", "paragraph_refs"],
        "properties": {
          "deviation_id": { "type": "string", "minLength": 1 },
          "rule_id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "paragraph_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^p[0-9]+$" }
          },
          "data_support_note": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "accepted", "to_review", "rejected"] },
          "dm_comment": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
