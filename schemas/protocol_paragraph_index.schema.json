{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pd-check-factory/schemas/protocol_paragraph_index.schema.json",
  "title": "Protocol paragraph index",
  "type": "object",
  "required": ["schema_version", "study_id", "generated_at", "paragraphs"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "study_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "paragraphs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paragraph_id", "text"],
        "properties": {
          "paragraph_id": { "type": "string", "pattern": "^p[0-9]+$" },
          "text": { "type": "string", "minLength": 1 },
          "char_start": { "type": "integer", "minimum": 0 },
          "char_end": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
