{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pd-check-factory/schemas/final_deviations_v2.schema.json",
  "title": "Final deviations V2",
  "type": "object",
  "required": ["schema_version", "study_id", "generated_at", "items"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "study_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "deviation_id", "deviation_text", "paragraph_refs", "pseudo_logic"],
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "deviation_id": { "type": "string", "minLength": 1 },
          "rule_title": { "type": "string" },
          "deviation_text": { "type": "string", "minLength": 1 },
          "paragraph_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^p[0-9]+$" }
          },
          "pseudo_logic": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
