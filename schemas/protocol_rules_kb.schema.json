{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pd-check-factory/schemas/protocol_rules_kb.schema.json",
  "title": "Protocol Rules Knowledge Base",
  "type": "object",
  "required": ["schema_version", "study_id", "generated_at", "rules"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "study_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rule_id", "title", "plain_language_requirement"],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^rule:[a-zA-Z0-9._-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string"
          },
          "plain_language_requirement": {
            "type": "string",
            "minLength": 1
          },
          "applies_to": {
            "type": "string"
          },
          "source_hints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
