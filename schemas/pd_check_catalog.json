{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PD Check Catalog Schema",
  "description": "Schema for PD Check catalogs generated from protocol/CRF/specs",
  "type": "object",
  "required": ["study_id", "version", "created_at", "status", "checks"],
  "properties": {
    "study_id": {
      "type": "string",
      "description": "Unique study identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Catalog version number"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when catalog was created"
    },
    "created_by": {
      "type": "string",
      "description": "User or system that created the catalog"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "pending_review", "approved", "rejected"],
      "description": "Current status of the catalog"
    },
    "checks": {
      "type": "array",
      "description": "Array of PD checks",
      "items": {
        "type": "object",
        "required": ["check_id", "name", "category", "severity", "protocol_refs", "inputs", "logic", "output_message", "dm_status"],
        "properties": {
          "check_id": {
            "type": "string",
            "pattern": "^CHK\\d{3,}$",
            "description": "Unique check identifier (e.g., CHK001)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable check name"
          },
          "category": {
            "type": "string",
            "enum": ["timing", "missing", "sequence", "inclusion", "dose", "other"],
            "description": "Check category"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "info"],
            "description": "Severity level of the check"
          },
          "protocol_refs": {
            "type": "array",
            "description": "References to source protocol sections",
            "items": {
              "type": "object",
              "required": ["doc"],
              "properties": {
                "doc": {
                  "type": "string",
                  "description": "Source document filename"
                },
                "section": {
                  "type": "string",
                  "description": "Section name or heading"
                },
                "page": {
                  "type": "integer",
                  "description": "Page number"
                },
                "table_id": {
                  "type": "string",
                  "description": "Reference to specific table if applicable"
                }
              }
            }
          },
          "inputs": {
            "type": "array",
            "description": "Required input datasets and columns",
            "items": {
              "type": "object",
              "required": ["dataset"],
              "properties": {
                "dataset": {
                  "type": "string",
                  "description": "Dataset name (e.g., SV, DM, EX)"
                },
                "columns": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Required columns from the dataset"
                },
                "join_keys": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Keys for joining with other datasets"
                }
              }
            }
          },
          "logic": {
            "type": "object",
            "description": "Structured check logic definition",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["window_check", "missing_check", "sequence_check", "inclusion_check", "dose_timing", "custom"],
                "description": "Type of check logic"
              },
              "description": {
                "type": "string",
                "description": "Human-readable description of the logic"
              }
            },
            "additionalProperties": true
          },
          "output_message": {
            "type": "string",
            "description": "Template message for check failures (may include {placeholders})"
          },
          "output_fields": {
            "type": "array",
            "description": "Fields to include in output when check fails",
            "items": {
              "type": "string"
            }
          },
          "dm_status": {
            "type": "string",
            "enum": ["pending_review", "approved", "rejected", "needs_revision"],
            "description": "DM review status"
          },
          "dm_comments": {
            "type": "string",
            "description": "Comments from DM reviewer"
          },
          "dm_reviewed_at": {
            "type": "string",
            "format": "date-time",
            "description": "When DM reviewed this check"
          },
          "dm_reviewed_by": {
            "type": "string",
            "description": "DM reviewer identifier"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata about the catalog",
      "properties": {
        "protocol_version": {
          "type": "string"
        },
        "source_documents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "total_checks": {
          "type": "integer"
        }
      }
    }
  }
}
