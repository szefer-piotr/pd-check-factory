{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Study Configuration Schema",
  "description": "Configuration for a study including dataset paths and assumptions",
  "type": "object",
  "required": ["study_id", "protocol_version"],
  "properties": {
    "study_id": {
      "type": "string",
      "description": "Unique study identifier"
    },
    "protocol_version": {
      "type": "string",
      "description": "Protocol version number"
    },
    "dataset_paths": {
      "type": "object",
      "description": "Paths to EDC extract datasets",
      "additionalProperties": {
        "type": "string",
        "description": "Path to dataset file (CSV/Parquet)"
      }
    },
    "id_columns": {
      "type": "object",
      "description": "Identifier columns for joining datasets",
      "properties": {
        "subject_id": {
          "type": "string",
          "default": "USUBJID"
        },
        "visit_id": {
          "type": "string",
          "default": "VISITNUM"
        }
      }
    },
    "timezone": {
      "type": "string",
      "default": "UTC",
      "description": "Timezone for datetime parsing"
    },
    "date_format": {
      "type": "string",
      "default": "ISO8601",
      "description": "Expected date format in datasets"
    }
  }
}
