{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Extracted Document Schema",
  "description": "Schema for documents extracted by Azure Document Intelligence",
  "type": "object",
  "required": ["source_file", "doc_type", "extracted_at"],
  "properties": {
    "source_file": {
      "type": "string",
      "description": "Original filename of the uploaded document"
    },
    "doc_type": {
      "type": "string",
      "enum": ["protocol", "crf", "specs"],
      "description": "Type of document"
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when extraction was performed"
    },
    "pages": {
      "type": "array",
      "description": "Array of page objects with text content and bounding boxes",
      "items": {
        "type": "object",
        "properties": {
          "page_number": {
            "type": "integer"
          },
          "width": {
            "type": "number"
          },
          "height": {
            "type": "number"
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "description": "Document sections with headings and content",
      "items": {
        "type": "object",
        "properties": {
          "heading": {
            "type": "string",
            "description": "Section heading text"
          },
          "level": {
            "type": "integer",
            "description": "Heading level (1-6)"
          },
          "content": {
            "type": "string",
            "description": "Section content text"
          },
          "page": {
            "type": "integer",
            "description": "Page number where section appears"
          }
        }
      }
    },
    "tables": {
      "type": "array",
      "description": "Extracted tables from the document",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the table"
          },
          "page": {
            "type": "integer",
            "description": "Page number where table appears"
          },
          "caption": {
            "type": "string",
            "description": "Table caption or title"
          },
          "row_count": {
            "type": "integer"
          },
          "column_count": {
            "type": "integer"
          },
          "rows": {
            "type": "array",
            "description": "Table rows as arrays of cell values",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "headers": {
            "type": "array",
            "description": "Table header row",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "paragraphs": {
      "type": "array",
      "description": "Paragraphs with reading order",
      "items": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "page": {
            "type": "integer"
          },
          "order": {
            "type": "integer",
            "description": "Reading order index"
          }
        }
      }
    },
    "key_value_pairs": {
      "type": "array",
      "description": "Extracted key-value pairs",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
