{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pd-check-factory/schemas/rules_parsed_v2.schema.json",
  "title": "Parsed rules V2",
  "type": "object",
  "required": ["schema_version", "study_id", "generated_at", "rules"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "study_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "title", "text", "paragraph_refs"],
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "paragraph_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^p[0-9]+$" }
          },
          "coverage_note": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
