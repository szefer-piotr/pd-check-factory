{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pd-check-factory/schemas/protocol_section_step1.schema.json",
  "title": "Protocol section Step 1 extraction",
  "type": "object",
  "required": [
    "schema_version",
    "study_id",
    "generated_at",
    "section_id",
    "section_path",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0.0"
    },
    "study_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "section_id": {
      "type": "string",
      "minLength": 1
    },
    "section_path": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "title",
          "atomic_requirement",
          "sentence_refs",
          "candidate_deviations"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "atomic_requirement": {
            "type": "string",
            "minLength": 1
          },
          "sentence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "candidate_deviations": {
            "type": "array",
            "minItems": 1,
            "description": "One rule can have multiple candidate_deviations depending on rule form/scope.",
            "items": {
              "type": "object",
              "required": [
                "deviation_id",
                "scenario_description",
                "example_violation_narrative",
                "sentence_refs",
                "programmable"
              ],
              "properties": {
                "deviation_id": {
                  "type": "string",
                  "minLength": 1
                },
                "scenario_description": {
                  "type": "string",
                  "minLength": 1
                },
                "example_violation_narrative": {
                  "type": "string",
                  "minLength": 1
                },
                "sentence_refs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "programmable": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
