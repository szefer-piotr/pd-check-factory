{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pd-check-factory/schemas/protocol_sections_step2_merged.schema.json",
  "title": "Protocol sections Step 2 merged output",
  "type": "object",
  "required": [
    "schema_version",
    "study_id",
    "generated_at",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.1.0"
    },
    "study_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "title",
          "atomic_requirement",
          "sentence_refs",
          "source_section_ids",
          "source_section_paths",
          "candidate_deviations"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "atomic_requirement": {
            "type": "string",
            "minLength": 1
          },
          "sentence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "source_section_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "source_section_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "candidate_deviations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "deviation_id",
                "scenario_description",
                "example_violation_narrative",
                "sentence_refs",
                "programmable",
                "source_section_ids",
                "source_section_paths"
              ],
              "properties": {
                "deviation_id": {
                  "type": "string",
                  "minLength": 1
                },
                "scenario_description": {
                  "type": "string",
                  "minLength": 1
                },
                "example_violation_narrative": {
                  "type": "string",
                  "minLength": 1
                },
                "sentence_refs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "programmable": {
                  "type": "boolean"
                },
                "source_section_ids": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "source_section_paths": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
