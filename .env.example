# Azure AI Document Intelligence (Layout)
DI_ENDPOINT="https://<your-resource>.cognitiveservices.azure.com/"
DI_KEY="<your-document-intelligence-key>"
# Optional override (default prebuilt-layout)
# DI_MODEL_ID="prebuilt-layout"
# DI_SAS_TTL_MINUTES="15"

# Azure Blob Storage
STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net"
STORAGE_CONTAINER="pdcheckfactory"
# Optional: SDK defaults are aggressive (read 60s); large layout JSON uploads often need more.
# AZURE_BLOB_CONNECTION_TIMEOUT_SEC="60"
# AZURE_BLOB_READ_TIMEOUT_SEC="600"
# Use multipart upload for blobs larger than this many MB (default 8; SDK default single-PUT up to 64MB).
# Applied on BlobServiceClient (not per upload_blob — see azure-storage-blob _upload_blob_options).
# AZURE_BLOB_MAX_SINGLE_PUT_MB="8"

# Study identifier for CLI defaults
STUDY_ID="INI-2004-102"

# Azure OpenAI (chat completions — used for rules extraction + PD drafting)
AZURE_OPENAI_ENDPOINT="https://<your-resource>.openai.azure.com/"
AZURE_OPENAI_API_KEY="<your-azure-openai-key>"
AZURE_OPENAI_DEPLOYMENT="<your-chat-deployment-name>"
# API version for the Azure OpenAI control plane / chat route
OPENAI_API_VERSION="2024-08-01-preview"

# Default blob layout: raw/<STUDY_ID>/protocol.pdf and raw/<STUDY_ID>/acrf.pdf
# (override with pdcheck extract --protocol-blob / --acrf-blob as needed)
